# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server
PORT=3001
NODE_ENV=development

# Redis (Render)
REDIS_URL=redis://localhost:6379

# AI Pipeline
AI_PIPELINE_URL=http://localhost:8000

# CORS (comma-separated origins for browser → API requests; required in production)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# AI soundtrack generation (Replicate text-to-music). Optional — when unset,
# generate_soundtrack=true requests fall back to the curated music library.
# Get a token at https://replicate.com/account/api-tokens
# REPLICATE_API_TOKEN=
# Optional model override (default: meta/musicgen). Pin a specific version
# for cost/quality stability.
# REPLICATE_MUSIC_MODEL=

# Per-user daily cap for AI soundtrack generations (cost guardrail).
# SOUNDTRACK_GEN_RATE_LIMIT_MAX=5
# SOUNDTRACK_GEN_RATE_LIMIT_WINDOW_MS=86400000

# AI custom mood generation (Anthropic Claude). When unset, the
# /api/custom-moods endpoint returns 503 and clients fall back to
# preset moods. Roughly $0.01 per generation on claude-opus-4-7.
# Get a key at https://console.anthropic.com
# ANTHROPIC_API_KEY=

# Per-user daily cap for custom mood generations (cost guardrail).
# CUSTOM_MOOD_RATE_LIMIT_MAX=10
# CUSTOM_MOOD_RATE_LIMIT_WINDOW_MS=86400000
